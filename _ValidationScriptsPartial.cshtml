@model KargoTakipSistemi1.Models.Personel

@{
    ViewData["Title"] = "Personel Detayư";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="page-title mb-1">Personel Detayư</h2>

            <p class="text-muted mb-0">
                Personel bilgilerini görüntüleyebilirsiniz.
            </p>
        </div>

        <a asp-action="Index"
           class="soft-action-btn back-btn">
            Listeye Dön
        </a>

    </div>

    <div class="content-card">

        <div class="detail-header-box mb-4">

            <span class="detail-status-label">
                Personel Bilgisi
            </span>

            <h4>@Model.AdSoyad</h4>

            <p>
                Personelin sistemde kayưtlư detay bilgileri.
            </p>

        </div>

        <div class="cargo-detail-grid">

            <div>
                <span>Ad Soyad</span>
                <strong>@Model.AdSoyad</strong>
            </div>

            <div>
                <span>Görev</span>
                <strong>@Model.Gorev</strong>
            </div>

            <div>
                <span>Telefon</span>
                <strong>@Model.Telefon</strong>
            </div>

            <div>
                <span>̃ube</span>
                <strong>@Model.Sube?.Adres</strong>
            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <a asp-action="Edit"
               asp-route-id="@Model?.Id"
               class="soft-action-btn back-btn">
                Düzenle
            </a>

            <a asp-action="Delete"
               asp-route-id="@Model?.Id"
               class="soft-action-btn delete">
                Sil
            </a>

        </div>

    </div>

</div>