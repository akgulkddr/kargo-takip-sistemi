@model KargoTakipSistemi1.Models.Musteri

@{
    ViewData["Title"] = "Yeni Müžteri Ekle";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="page-title mb-1">Yeni Müžteri Ekle</h2>

            <p class="text-muted mb-0">
                Sisteme yeni müžteri bilgisi ekleyin.
            </p>
        </div>

        <a asp-action="Index"
           class="soft-action-btn back-btn">
            Listeye Dön
        </a>

    </div>

    <div class="content-card">

        <div class="detail-header-box mb-4">

            <span class="detail-status-label">
                Müžteri Formu
            </span>

            <h4>Yeni Müžteri Olužtur</h4>

            <p>
                Müžteri bilgilerini doldurarak kayżt olužturabilirsiniz.
            </p>

        </div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row g-3">

                <div class="col-md-6">

                    <label asp-for="AdSoyad"
                           class="form-label">
                        Ad Soyad
                    </label>

                    <input asp-for="AdSoyad"
                           class="form-control" />

                    <span asp-validation-for="AdSoyad"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Telefon"
                           class="form-label">
                        Telefon
                    </label>

                    <input asp-for="Telefon"
                           class="form-control" />

                    <span asp-validation-for="Telefon"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Email"
                           class="form-label">
                        Email
                    </label>

                    <input asp-for="Email"
                           class="form-control" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-12">

                    <label asp-for="Adres"
                           class="form-label">
                        Žehir
                    </label>

                    <select asp-for="Adres"
                            class="form-select"
                            id="sehirSelect">

                        <option value="">Žehir seēiniz</option>

                    </select>

                    <span asp-validation-for="Adres"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="mt-4 d-flex gap-2">

                <button type="submit"
                        class="soft-action-btn back-btn border-0">
                    Kaydet
                </button>

                <a asp-action="Index"
                   class="soft-action-btn detail">
                    Vazgeē
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/il-ilce.js"></script>

    <script>

        const sehirler = Object.keys(ilceler);

        const sehirSelect =
            document.getElementById("sehirSelect");

        sehirler.forEach(function (sehir) {

            const option =
                document.createElement("option");

            option.value = sehir;

            option.textContent = sehir;

            sehirSelect.appendChild(option);
        });

    </script>
}
}