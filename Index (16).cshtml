@model IEnumerable<KargoTakipSistemi1.Models.Musteri>

@{
    ViewData["Title"] = "Müşteriler";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Müşteriler</h2>
            <p class="text-muted mb-0">Sistemde kayıtlı müşterileri görüntüleyin ve yönetin.</p>
        </div>

        <a asp-action="Create" class="soft-action-btn back-btn">
            + Yeni Müşteri Ekle
        </a>
    </div>

    <div class="content-card">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Email</th>
                    <th>Adres</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="soft-badge">
                                @item.AdSoyad
                            </span>
                        </td>

                        <td>@item.Telefon</td>
                        <td>@item.Email</td>
                        <td>@item.Adres</td>

                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="soft-action-btn back-btn">
                                Düzenle
                            </a>

                            <a asp-action="Details" asp-route-id="@item.Id" class="soft-action-btn back-btn">
                                Detay
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="soft-action-btn delete">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>