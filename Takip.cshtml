@model KargoTakipSistemi1.Models.Kargo

@{
    ViewData["Title"] = "Kargo Sil";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="page-title mb-1 text-danger">Kargo Sil</h2>

            <p class="text-muted mb-0">
                Bu kargoyu silmek istediđinizden emin misiniz?
            </p>
        </div>

        <a asp-action="Index"
           class="soft-action-btn back-btn">
            Listeye Dön
        </a>

    </div>

    <div class="content-card">

        <div class="detail-header-box delete-header-box mb-4">

            <span class="detail-status-label delete-label">
                Silme Ýţlemi
            </span>

            <h4>@Model.TakipNo</h4>

            <p>
                Bu iţlem geri alýnamaz.
            </p>

        </div>

        <div class="cargo-detail-grid">

            <div>
                <span>Takip No</span>
                <strong>@Model.TakipNo</strong>
            </div>

            <div>
                <span>Kargo Türü</span>
                <strong>@Model.KargoTuru</strong>
            </div>

            <div>
                <span>Ađýrlýk</span>
                <strong>@Model.Agirlik kg</strong>
            </div>

            <div>
                <span>Gönderim Tarihi</span>
                <strong>@Model.GonderimTarihi.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div>
                <span>Gönderici</span>
                <strong>@Model.Gonderici?.AdSoyad</strong>
            </div>

            <div>
                <span>Alýcý</span>
                <strong>@Model.Alici?.AdSoyad</strong>
            </div>

            <div>
                <span>Çýkýţ Ţubesi</span>
                <strong>@Model.CikisSube?.SubeAdi</strong>
            </div>

            <div>
                <span>Varýţ Ţubesi</span>
                <strong>@Model.VarisSube?.SubeAdi</strong>
            </div>

        </div>

        <form asp-action="Delete"
              class="mt-4 d-flex gap-2"
              id="deleteForm">

            <input type="hidden" asp-for="Id" />

            <button type="button"
                    class="soft-action-btn delete border-0"
                    onclick="openDeleteModal()">
                Evet, Sil
            </button>

            <a asp-action="Index"
               class="soft-action-btn detail">
                Vazgeç
            </a>

        </form>

    </div>

</div>

<div id="deleteModal" class="custom-modal-overlay">

    <div class="custom-modal-box">

        <div class="custom-modal-icon">
            !
        </div>

        <h4>Silme Ýţlemi</h4>

        <p>
            Bu kargoyu silmek istediđinize emin misiniz?
        </p>

        <div class="d-flex justify-content-center gap-2 mt-4">

            <button type="button"
                    class="soft-action-btn delete border-0"
                    onclick="submitDeleteForm()">
                Evet, Sil
            </button>

            <button type="button"
                    class="soft-action-btn detail border-0"
                    onclick="closeDeleteModal()">
                Vazgeç
            </button>

        </div>

    </div>

</div>

<script>
    function openDeleteModal() {
        document.getElementById("deleteModal").classList.add("show");
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").classList.remove("show");
    }

    function submitDeleteForm() {
        document.getElementById("deleteForm").submit();
    }
</script>